PORT=3000
NODE_ENV=production

# Use either DATABASE_URL or the DB_* values below.
DATABASE_URL=postgresql://user:password@host:5432/database
DB_SSL=true

DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cya_db

SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com

# Set this to your deployed site URL, for example:
# https://your-app.onrender.com
APP_ORIGIN=
CORS_ALLOWED_ORIGINS=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional but strongly recommended on free hosts, because local uploads are ephemeral.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=cya-platform/gallery
